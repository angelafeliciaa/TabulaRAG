API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=

# Transactional email (Brevo SMTP). If SMTP_HOST is empty, verification/reset codes are only written to
# backend logs — nothing is sent, and Brevo usage stays at 0.
# Brevo: Transactional > SMTP & API — create an SMTP key. Use the SMTP login email as SMTP_USER and the
# SMTP key (not your Brevo login password) as SMTP_PASSWORD. SMTP_FROM must be a sender you verified in Brevo.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=a76f52001@smtp-brevo.com
SMTP_PASSWORD=
SMTP_FROM=a76f52001@smtp-brevo.com
SMTP_USE_TLS=true

PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_UI_BASE_URL=http://localhost:5173

POSTGRES_DB=tabularag
POSTGRES_USER=tabularag
POSTGRES_PASSWORD=tabularag_dev_password
DATABASE_URL=postgresql://tabularag:tabularag_dev_password@postgres:5432/tabularag

QDRANT_URL=http://qdrant:6333
QDRANT_TIMEOUT_SECONDS=60
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_THREADS=4
EMBEDDING_BATCH_SIZE=768
INDEX_EMBED_BATCH_SIZE=768
INDEX_EMBED_MIN_BATCH_SIZE=64
INDEX_PROGRESS_TARGET_UPDATES=12
INDEX_WORKER_CONCURRENCY=4
QDRANT_UPSERT_BATCH_SIZE=1000
QDRANT_UPSERT_PARALLEL=2
QDRANT_UPSERT_WAIT=false
QDRANT_BULK_INGEST_MODE=true
QDRANT_BULK_HNSW_M=0
QDRANT_BULK_INDEXING_THRESHOLD=0
QDRANT_FINAL_HNSW_M=16
QDRANT_FINAL_INDEXING_THRESHOLD=20000
